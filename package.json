{
  "name": "betterprompt",
  "version": "0.0.2-dev.8",
  "type": "module",
  "description": "BetterPrompt CLI Tools.",
  "bin": {
    "betterprompt": "bin/betterprompt.js",
    "bp": "bin/betterprompt.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "build": "bun build ./src/cli.ts --outdir ./dist --target node",
    "prerelease": "bun pm version prerelease --preid=dev --no-git-tag-version && bun run build && bun publish --tag latest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "author": "BetterPrompt",
  "devDependencies": {
    "@clack/prompts": "^1.0.1",
    "@eslint/js": "^9.39.3",
    "@types/bun": "^1.3.9",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "log-symbols": "^7.0.1",
    "ora": "^9.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
